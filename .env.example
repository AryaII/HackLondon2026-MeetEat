# Copy this file to .env.local and fill in your keys.
# Vite only exposes VITE_-prefixed vars to client code via import.meta.env.

# Required for AI-written recommendation explanations (src/utils/aiClient.ts).
# Get a key from the hackathon Discord / https://zai-hackathon.zeabur.app/
VITE_GLM_API_KEY="your-glm-api-key"

# Optional — renders the participant/restaurant map (src/components/MapVisualization.tsx).
# Without it the app runs fine and shows a setup guide in place of the map.
VITE_GOOGLE_MAPS_PLATFORM_KEY="your-google-maps-platform-key"
